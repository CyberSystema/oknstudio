# ── Python ────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
build/
dist/

# ── Node / TypeScript ─────────────────────────────────
node_modules/
package-lock.json
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Cloudflare Wrangler / Pages ───────────────────────
.wrangler/
.mf/
.dev.vars
.dev.vars.*
wrangler.toml.local

# ── Env / secrets ─────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ── Generated (rebuilt on every deploy) ───────────────
site/assets/

# ── OS ────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editors / IDE ─────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.history/

# ── Logs ──────────────────────────────────────────────
*.log
logs/

# ── GitHub Copilot customization (local user overrides) ─
.github/copilot-instructions.local.md
.github/agents/*.local.agent.md
.github/prompts/*.local.prompt.md

# ── Autonomy & operations (transient artifacts) ────────
autonomy-playbooks.md
autonomy-report-*.json
autonomy-check-output.txt
.autonomy-cache/

# ── Local working data (ingest staging — never commit exports) ─
analytics-pipeline/data/**/*.csv
analytics-pipeline/data/**/*.xlsx
analytics-pipeline/data/**/*.json
!analytics-pipeline/data/**/.gitkeep
analytics-pipeline/data/**/*.gz
analytics-pipeline/history/*.json.bak
analytics-pipeline/history/*.csv.bak

# ── Darkroom audit & temporary files ───────────────────
site/darkroom/DARKROOM_AUDIT.md
site/darkroom/*.tmp.*
site/darkroom/.working/
